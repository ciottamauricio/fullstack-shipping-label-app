# EasyPost API key — get a free test key at https://easypost.com/account/api-keys
# Test keys start with EZAK and generate real-looking labels at no cost
EASYPOST_API_KEY=

# Database credentials — must match the values in docker-compose.yml
DB_DATABASE=shipping_labels
DB_USERNAME=laravel
DB_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret
